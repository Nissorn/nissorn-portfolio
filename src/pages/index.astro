---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const projectsOnly = allNotes.filter(note => note.id.startsWith('01-Projects/'));
---

<Layout>
  <section class="mt-20 mb-24 flex flex-col md:flex-row items-center gap-10 animate-fade-in-up delay-100">
    <div class="relative w-48 h-48 shrink-0">
      <div class="absolute inset-0 bg-red-500 rounded-2xl blur-md opacity-20 dark:opacity-40"></div>
      <img src="/profile.jpg" alt="Nissorn Koraviyothin" class="relative w-full h-full object-cover rounded-2xl border border-zinc-200/50 dark:border-zinc-800/50" />
    </div>
    
    <div>
      <h1 class="text-5xl md:text-6xl font-bold text-black dark:text-white tracking-tight mb-4 font-sans flex items-center gap-4">
        Hi, I'm Nissorn
        <span class="w-3 h-3 bg-red-500 rounded-sm inline-block"></span>
      </h1>
      <h2 class="text-xl text-zinc-500 font-mono mb-4">
        > Computer Engineering @ KU SRC
      </h2>
      <p class="text-zinc-600 dark:text-zinc-400 max-w-xl leading-relaxed">
        Third-year Computer Engineering student aspiring to become an AI Engineer. 
        2 years of experience as a Data Analyst and Technical Staff at Cybergeek Club. 
        Eager to contribute to Singapodent.
      </p>
      
      <div class="mt-8 flex gap-4 font-mono text-sm uppercase tracking-wider">
        <a href="#projects" class="bg-black text-white dark:bg-white dark:text-black hover:bg-red-500 dark:hover:bg-red-500 hover:text-white dark:hover:text-white py-3 px-8 rounded-lg transition-colors border border-transparent backdrop-blur-md">
          View Projects
        </a>
        <a href="https://github.com/Nissorn" target="_blank" rel="noopener noreferrer" class="backdrop-blur-md bg-white/50 dark:bg-black/50 border border-zinc-200/50 dark:border-zinc-800/50 hover:border-black dark:hover:border-white text-black dark:text-white py-3 px-8 rounded-lg transition-colors">
          GitHub
        </a>
      </div>
    </div>
  </section>

  <section id="tech-specs" class="mb-24 animate-fade-in-up delay-200">
    <h3 class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-8 flex items-center gap-3">
      <span class="w-1.5 h-1.5 bg-red-500"></span>
      Tech Specs
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Languages -->
      <div class="bg-white/95 dark:bg-black/60 shadow-sm dark:shadow-none backdrop-blur-md border border-zinc-300/80 dark:border-zinc-800/50 p-6 rounded-lg relative overflow-hidden group">
        <div class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-transparent via-red-500/20 to-transparent group-hover:via-red-500/50 transition-all duration-300"></div>
        <h4 class="text-zinc-900 dark:text-white font-mono text-sm uppercase tracking-wider mb-4 border-b border-zinc-200/50 dark:border-zinc-800/50 pb-2">Languages</h4>
        <div class="flex flex-wrap gap-2 font-mono">
          {['Python', 'C/C++', 'SQL', 'MATLAB'].map((skill) => (
            <span class="bg-zinc-100/50 dark:bg-zinc-900/50 border border-zinc-200/50 dark:border-zinc-800/50 text-zinc-600 dark:text-zinc-400 text-xs px-2 py-1 rounded-md uppercase tracking-wider">
              {skill}
            </span>
          ))}
        </div>
      </div>
      <!-- AI & ML -->
      <div class="bg-white/95 dark:bg-black/60 shadow-sm dark:shadow-none backdrop-blur-md border border-zinc-300/80 dark:border-zinc-800/50 p-6 rounded-lg relative overflow-hidden group">
         <div class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-transparent via-red-500/20 to-transparent group-hover:via-red-500/50 transition-all duration-300"></div>
        <h4 class="text-zinc-900 dark:text-white font-mono text-sm uppercase tracking-wider mb-4 border-b border-zinc-200/50 dark:border-zinc-800/50 pb-2">AI & ML</h4>
        <div class="flex flex-wrap gap-2 font-mono">
          {['OpenCV', 'YOLOv8', 'PyTorch', 'Scikit-learn', 'Pandas', 'Numpy', 'Transformers'].map((skill) => (
            <span class="bg-zinc-100/50 dark:bg-zinc-900/50 border border-zinc-200/50 dark:border-zinc-800/50 text-zinc-600 dark:text-zinc-400 text-xs px-2 py-1 rounded-md uppercase tracking-wider">
              {skill}
            </span>
          ))}
        </div>
      </div>
      <!-- Tools -->
      <div class="bg-white/95 dark:bg-black/60 shadow-sm dark:shadow-none backdrop-blur-md border border-zinc-300/80 dark:border-zinc-800/50 p-6 rounded-lg relative overflow-hidden group">
         <div class="absolute top-0 left-0 w-full h-0.5 bg-gradient-to-r from-transparent via-red-500/20 to-transparent group-hover:via-red-500/50 transition-all duration-300"></div>
        <h4 class="text-zinc-900 dark:text-white font-mono text-sm uppercase tracking-wider mb-4 border-b border-zinc-200/50 dark:border-zinc-800/50 pb-2">Tools</h4>
        <div class="flex flex-wrap gap-2 font-mono">
          {['Git/GitHub', 'Linux (Bash)', 'Jupyter', 'Figma'].map((skill) => (
            <span class="bg-zinc-100/50 dark:bg-zinc-900/50 border border-zinc-200/50 dark:border-zinc-800/50 text-zinc-600 dark:text-zinc-400 text-xs px-2 py-1 rounded-md uppercase tracking-wider">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="system-log" class="mb-24 animate-fade-in-up delay-300">
    <h3 class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-8 flex items-center gap-3">
      <span class="w-1.5 h-1.5 bg-red-500"></span>
      System Log
    </h3>
    
    <div class="border-l border-zinc-200/50 dark:border-zinc-800/50 ml-2 pl-6 relative space-y-12">
      
      <!-- Education -->
      <div class="relative">
        <span class="absolute -left-[28.5px] top-1.5 w-2 h-2 bg-red-500 ring-4 ring-white dark:ring-black"></span>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 mb-2">
          <h4 class="text-lg font-bold text-zinc-900 dark:text-white font-sans tracking-tight">Kasetsart University, Sriracha Campus</h4>
          <span class="font-mono text-xs text-zinc-500 uppercase tracking-widest">Expected 2027</span>
        </div>
        <div class="text-zinc-700 dark:text-zinc-400 text-sm leading-relaxed p-4 bg-white/95 dark:bg-black/30 shadow-sm dark:shadow-none backdrop-blur-sm border border-zinc-300/80 dark:border-zinc-800/50 rounded-lg">
          <p class="font-bold text-zinc-900 dark:text-white mb-2">B.E. Computer Engineering (3rd Year)</p>
          <div class="space-y-1 font-mono text-xs">
            <p>GPA: <span class="text-zinc-900 dark:text-zinc-200">3.01</span></p>
            <p>Coursework: <span class="text-zinc-900 dark:text-zinc-200">AI & Data Science, Software & Systems</span></p>
          </div>
        </div>
      </div>

      <!-- Cybergeek Club -->
      <div class="relative">
        <span class="absolute -left-[28.5px] top-1.5 w-2 h-2 bg-red-500 ring-4 ring-white dark:ring-black"></span>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 mb-2">
          <h4 class="text-lg font-bold text-zinc-900 dark:text-white font-sans tracking-tight">Cybergeek Club</h4>
          <span class="font-mono text-xs text-zinc-500 uppercase tracking-widest">2024 - Present</span>
        </div>
        <div class="text-zinc-700 dark:text-zinc-400 text-sm leading-relaxed p-4 bg-white/95 dark:bg-black/30 shadow-sm dark:shadow-none backdrop-blur-sm border border-zinc-300/80 dark:border-zinc-800/50 rounded-lg">
          <p>Instructor (Prompt Engineering), Technical Operations (End-to-end management), Data Analyst.</p>
        </div>
      </div>

      <!-- TESA -->
      <div class="relative">
        <span class="absolute -left-[28.5px] top-1.5 w-2 h-2 bg-red-500 ring-4 ring-white dark:ring-black"></span>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 mb-2">
          <h4 class="text-lg font-bold text-zinc-900 dark:text-white font-sans tracking-tight">TESA Top Gun Rally</h4>
          <span class="font-mono text-xs text-zinc-500 uppercase tracking-widest">Nov 2025</span>
        </div>
        <div class="text-zinc-700 dark:text-zinc-400 text-sm leading-relaxed p-4 bg-white/95 dark:bg-black/30 shadow-sm dark:shadow-none backdrop-blur-sm border border-zinc-300/80 dark:border-zinc-800/50 rounded-lg">
          <p>Embedded systems with MATLAB, YOLO model for Drone Detection.</p>
        </div>
      </div>
      
    </div>
  </section>

  <section id="projects" class="pt-10 border-t border-zinc-200/50 dark:border-zinc-800/50 animate-fade-in-up delay-400">
    <h3 class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-8 flex items-center gap-3">
      <span class="w-1.5 h-1.5 bg-red-500"></span>
      Selected Projects
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projectsOnly.map((note) => {
        const projectUrl = `/projects/${note.id.replace('01-Projects/', '').replace('.mdx', '').replace('.md', '')}`;
        return (
          <a href={projectUrl} class="group block bg-white/95 dark:bg-black/60 shadow-sm dark:shadow-none backdrop-blur-xl border border-zinc-300/80 dark:border-zinc-800/50 p-8 rounded-lg hover:border-red-500 dark:hover:border-red-500 transition-all duration-300 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-red-500 transform -translate-x-full group-hover:translate-x-0 transition-transform duration-300"></div>
            <h4 class="text-xl font-bold text-zinc-900 dark:text-white mb-3">
              {note.data.title}
            </h4>
            <p class="text-zinc-600 dark:text-zinc-400 mb-6 line-clamp-2 text-sm">
              {note.data.description}
            </p>
            <div class="flex flex-wrap gap-2 font-mono">
              {note.data.tags.map((tag) => (
                <span class="bg-zinc-100/50 dark:bg-zinc-900/50 border border-zinc-200/50 dark:border-zinc-800/50 text-zinc-600 dark:text-zinc-400 text-xs px-2 py-1 rounded-md uppercase tracking-wider">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
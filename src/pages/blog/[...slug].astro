---
// src/pages/blog/[...slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  const blogsOnly = allNotes.filter(note => note.id.startsWith('02-Blog/'));

  return blogsOnly.map(entry => ({
    params: { 
      slug: entry.id.replace('02-Blog/', '').replace('.mdx', '').replace('.md', '') 
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const toc = headings.filter((heading) => heading.depth >= 1 && heading.depth <= 3);

// Calculate reading time
const wordCount = entry.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
---
<Layout 
  title={`${entry.data.title} | Blog | My Portfolio`} 
  description={entry.data.description} 
  image={entry.data.image}
>
  <a href="/blog" class="group text-zinc-500 hover:text-red-500 dark:hover:text-red-500 mb-8 inline-block font-mono text-sm uppercase tracking-widest transition-colors flex items-center gap-2 w-fit">
    <span class="transform group-hover:-translate-x-1 transition-transform">←</span> Back to Blog
  </a>

  <article class="bg-white/60 dark:bg-black/60 backdrop-blur-xl border border-zinc-200/50 dark:border-zinc-800/50 p-8 rounded-lg relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-red-500/50 to-transparent"></div>
    <header class="mb-8 border-b border-zinc-200/50 dark:border-zinc-800/50 pb-8">
      <h1 class="text-4xl font-bold text-black dark:text-white mb-4 tracking-tight font-sans">{entry.data.title}</h1>
      <div class="flex gap-4 text-zinc-500 font-mono text-sm mb-4 items-center uppercase tracking-wider">
        <time>{entry.data.date.toISOString().split('T')[0]}</time>
        <span>•</span>
        <span>⏳ {readingTime} min read</span>
      </div>
      <div class="flex gap-2 font-mono mt-6">
        {entry.data.tags.map((tag: string) => (
          <span class="bg-zinc-100/50 dark:bg-zinc-900/50 border border-zinc-200/50 dark:border-zinc-800/50 text-zinc-600 dark:text-zinc-400 text-xs px-2 py-1 rounded-md uppercase tracking-wider">
            {tag}
          </span>
        ))}
      </div>
    </header>

    {toc.length > 0 && (
      <nav class="bg-white/50 dark:bg-black/50 backdrop-blur-md border border-zinc-200/50 dark:border-zinc-800/50 p-6 rounded-lg mb-10">
        <h2 class="text-lg font-bold text-black dark:text-white mb-4 flex items-center gap-2 tracking-tight">
          <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg>
          <span class="uppercase tracking-widest font-mono text-sm border-b border-red-500/30 pb-1">Table of Contents</span>
        </h2>
        <ul class="space-y-2 font-mono text-sm max-w-xl">
          {toc.map((heading) => (
            <li class={`
              ${heading.depth === 1 ? 'text-black dark:text-white font-bold mt-3 uppercase tracking-wider' : ''}
              ${heading.depth === 2 ? 'text-zinc-800 dark:text-zinc-200 ml-4' : ''}
              ${heading.depth === 3 ? 'text-zinc-500 dark:text-zinc-400 ml-8' : ''}
            `}>
              <a 
                href={`#${heading.slug}`} 
                class="hover:text-zinc-500 dark:hover:text-zinc-300 transition-colors flex items-center gap-2"
              >
                {heading.depth === 3 && <span class="w-1 h-1 bg-zinc-300 dark:bg-zinc-700 rounded-full shrink-0"></span>}
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="prose dark:prose-invert prose-zinc max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-a:text-red-500 dark:prose-a:text-red-500 hover:prose-a:text-red-600 dark:hover:prose-a:text-red-400 prose-a:decoration-red-500/30 hover:prose-a:decoration-red-500 prose-a:transition-colors">
      <Content />
      <script src="https://giscus.app/client.js"
        data-repo="Nissorn/nissorn-portfolio"
        data-repo-id="R_kgDONGq-OA"
        data-category="General"
        data-category-id="DIC_kwDONGq-OM4Cjy2k"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="noborder_light"
        data-lang="en"
        crossorigin="anonymous"
        async>
      </script>
    </div>
  </article>
</Layout>

---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="AI Engine API Console">
  <div class="min-h-screen w-full flex flex-col pt-24 pb-12 bg-white dark:bg-zinc-950 overflow-y-auto">
    <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 mb-8">
      <!-- Go Back Button -->
      <a href="javascript:void(0)" onclick="window.history.length > 1 ? window.history.back() : window.close()" class="inline-flex items-center gap-2 px-4 py-2 mb-6 text-sm font-medium text-zinc-600 dark:text-zinc-400 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg shadow-sm hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors w-max">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Go Back
      </a>

      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-6">
        <h1 class="text-2xl font-bold text-blue-900 dark:text-blue-100 mb-2">Interactive API Console</h1>
        <p class="text-blue-700 dark:text-blue-300">
          Test real API endpoints directly from your browser. Ensure your authentication tokens are set if required.
        </p>
      </div>
    </div>
    
    <div id="swagger-ui" class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 rounded-xl overflow-hidden bg-white dark:bg-zinc-900 shadow-sm border border-zinc-200 dark:border-zinc-800 pb-10"></div>
  </div>

  <link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5.11.0/swagger-ui.css" />
  <style is:global>
    /* Add some basic dark mode overrides for Swagger UI if needed */
    .dark .swagger-ui { filter: invert(0.88) hue-rotate(180deg); }
    .dark .swagger-ui .opblock .opblock-summary { border-color: rgba(0,0,0,0.1); }
  </style>
  <script is:inline src="https://unpkg.com/swagger-ui-dist@5.11.0/swagger-ui-bundle.js"></script>
  <script is:inline>
    window.onload = () => {
      window.ui = SwaggerUIBundle({
        url: '/schemas/swagger.json',
        dom_id: '#swagger-ui',
        deepLinking: true,
        presets: [
          SwaggerUIBundle.presets.apis,
          SwaggerUIBundle.SwaggerUIStandalonePreset
        ],
        layout: "BaseLayout",
      });
    };
  </script>
</Layout>

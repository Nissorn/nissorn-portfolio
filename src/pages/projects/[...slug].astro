---
// src/pages/projects/[...slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  const projectsOnly = allNotes.filter(note => note.id.startsWith('01-Projects/'));

  return projectsOnly.map(entry => ({
    params: { 
      // แก้ตรงนี้: ให้มันตัดทั้ง .mdx และ .md ทิ้งทั้งคู่
      slug: entry.id.replace('01-Projects/', '').replace('.mdx', '').replace('.md', '') 
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render(); 
---
<Layout>
  <a href="/" class="text-emerald-400 hover:text-emerald-300 mb-8 inline-block">
    ← Back to Home
  </a>

  <article class="bg-slate-900 border border-slate-800 p-8 rounded-2xl">
    <header class="mb-8 border-b border-slate-800 pb-8">
      <h1 class="text-4xl font-bold text-white mb-4">{entry.data.title}</h1>
      <div class="flex gap-4 text-slate-400 text-sm mb-4">
        <time>{entry.data.date.toISOString().split('T')[0]}</time>
      </div>
      <div class="flex gap-2">
        {entry.data.tags.map((tag: string) => (
          <span class="bg-slate-800 text-emerald-400 text-xs px-3 py-1 rounded-full">
            #{tag}
          </span>
        ))}
      </div>
    </header>

    <div class="prose prose-invert prose-emerald max-w-none">
      <Content />
    </div>
  </article>
</Layout>
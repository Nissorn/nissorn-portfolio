        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id",
            "description": "Unique session ID for the chat"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "The user's message"
          },
          "sheet_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sheet Id",
            "description": "Optional sheet ID for context injection (RAG)"
          }
        },
        "type": "object",
        "required": [
          "session_id",
          "message"
        ],
        "title": "ChatRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"

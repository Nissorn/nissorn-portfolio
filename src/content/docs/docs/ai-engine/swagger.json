              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/audio/transcribe": {
      "post": {
        "tags": [
          "Audio"
        ],
        "summary": "Transcribe Audio Background",
        "description": "Upload an audio file (mp3/wav) for background processing.\nReturns a job_id immediately.",
        "operationId": "transcribe_audio_background_api_audio_transcribe_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_transcribe_audio_background_api_audio_transcribe_post"

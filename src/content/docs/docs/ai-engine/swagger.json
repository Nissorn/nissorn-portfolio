              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sheets/jobs/by-sheet/{sheet_id}": {
      "get": {
        "tags": [
          "Sheets"
        ],
        "summary": "Get Job By Sheet",
        "description": "Poll job status by sheet_id.\nReturns the latest job associated with this sheet_id.",
        "operationId": "get_job_by_sheet_sheets_jobs_by_sheet__sheet_id__get",
        "parameters": [
          {
            "name": "sheet_id",
            "in": "path",
            "required": true,
